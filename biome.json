{
    "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": false
    },
    "files": {
        "ignoreUnknown": true,
        "includes": ["**", "!node_modules", "!.next", "!dist", "!build"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 96
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "a11y": {
                "useButtonType": "info",
                "useKeyWithClickEvents": "off",
                "noStaticElementInteractions": "off",
                "useSemanticElements": "info"
            },
            "suspicious": {
                "noUnknownAtRules": "warn",
                "noArrayIndexKey": "info",
                "noConsole": {
                    "fix": "none",
                    "level": "warn",
                    "options": {
                        "allow": ["warn", "table", "error", "info", "dir"]
                    }
                }
            },
            "correctness": {
                "recommended": true,
                "useExhaustiveDependencies": "warn",
                "noUnusedFunctionParameters": "warn",
                "noUnusedImports": "warn",
                "useUniqueElementIds": "info",
                "noUnusedVariables": "warn"
            }
        },
        "domains": {
            "react": "all"
        }
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "on",
                "useSortedAttributes": "on"
            }
        }
    },
    "javascript": {
        "formatter": {
            "enabled": true,
            "arrowParentheses": "always",
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "es5",
            "jsxQuoteStyle": "double"
        }
    },
    "overrides": [
        {
            "includes": ["__ideas__/**/*.ts", "__*.ts"],
            "linter": {
                "rules": {
                    "correctness": { "noUnusedVariables": "off" },
                    "suspicious": { "noConsole": "off" }
                }
            }
        }
    ]
}
